generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TOURIST
  USER
  GUIDE
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  IN_PROGRESS
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  ORDER_CREATED
  PAID
  FAILED
  REFUNDED
}

enum GuideVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id              String        @id @default(cuid())
  fullName        String
  email           String        @unique
  passwordHash    String
  phone           String?
  role            UserRole      @default(USER)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  guideProfile    GuideProfile?
  touristBookings Booking[]     @relation("TouristBookings")
  reviews         Review[]
}

model GuideProfile {
  id                 String                  @id @default(cuid())
  userId             String                  @unique
  city               String
  languages          String[]
  specialties        String[]
  bio                String?
  hourlyRate         Int?
  aadhaarNumber      String?
  panNumber          String?
  aadhaarImageBase64 String?                 @db.Text
  aadhaarImageMimeType String?
  panImageBase64     String?                 @db.Text
  panImageMimeType   String?
  passportPhotoBase64 String?                @db.Text
  passportPhotoMimeType String?
  verificationStatus GuideVerificationStatus @default(PENDING)
  isVerified         Boolean                 @default(false)
  isAvailable        Boolean                 @default(true)
  acceptingBookings  Boolean                 @default(true)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  bookings           Booking[]
  itineraries        Itinerary[]
  availabilityBlocks GuideAvailabilityBlock[]
  reviews            Review[]
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model City {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  summary       String?
  imageBase64   String      @db.Text
  imageMimeType String
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  places        CityPlace[]
}

model CityPlace {
  id            String   @id @default(cuid())
  cityId        String
  name          String
  slug          String
  summary       String?
  imageBase64   String   @db.Text
  imageMimeType String
  displayOrder  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  city          City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([cityId, slug])
  @@index([cityId, displayOrder])
}

model Booking {
  id             String        @id @default(cuid())
  touristId      String
  guideProfileId String
  travelDate     DateTime
  startAt        DateTime?
  endAt          DateTime?
  timezone       String?
  guestCount     Int           @default(1)
  meetingPoint   String?
  message        String?
  status         BookingStatus @default(PENDING)
  totalAmount    Int?
  paymentStatus  PaymentStatus @default(PENDING)
  paymentGateway String?
  paymentOrderId String?
  paymentId      String?
  paymentSignature String?
  paymentCurrency String?
  paymentAmount  Int?
  paymentPaidAt  DateTime?
  confirmedAt    DateTime?
  cancelledAt    DateTime?
  completedAt    DateTime?
  cancellationReason String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  guideProfile   GuideProfile  @relation(fields: [guideProfileId], references: [id], onDelete: Cascade)
  tourist        User          @relation("TouristBookings", fields: [touristId], references: [id], onDelete: Cascade)
  itinerary      Itinerary?
  review         Review?

  @@index([guideProfileId, status, startAt, endAt])
  @@index([touristId, status, travelDate])
}

model Itinerary {
  id             String       @id @default(cuid())
  guideProfileId String
  bookingId      String?      @unique
  title          String
  summary        String?
  stops          Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  booking        Booking?     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  guideProfile   GuideProfile @relation(fields: [guideProfileId], references: [id], onDelete: Cascade)
}

model Review {
  id             String       @id @default(cuid())
  touristId      String
  guideProfileId String
  bookingId      String?      @unique
  rating         Int
  comment        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  booking        Booking?     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  guideProfile   GuideProfile @relation(fields: [guideProfileId], references: [id], onDelete: Cascade)
  tourist        User         @relation(fields: [touristId], references: [id], onDelete: Cascade)

  @@index([guideProfileId, createdAt])
  @@index([touristId, createdAt])
}

model GuideAvailabilityBlock {
  id             String       @id @default(cuid())
  guideProfileId String
  startAt        DateTime
  endAt          DateTime
  reason         String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  guideProfile   GuideProfile @relation(fields: [guideProfileId], references: [id], onDelete: Cascade)

  @@index([guideProfileId, startAt, endAt])
}
